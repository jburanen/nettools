# ============================================================
# NetTools — optional theming / branding configuration
#
# Copy this file to ".env" (same directory as docker-compose.yml)
# and uncomment/change only the lines you care about. Every
# setting is OPTIONAL: anything left commented out (or an empty
# .env, or no .env at all) falls back to the built-in default
# shown to the right of each line.
#
# After editing, apply with:  docker-compose up -d --build
# (the values are baked into a small generated stylesheet/script
#  at container startup — no rebuild of your HTML is needed.)
# ============================================================

# ---- Deployment ----------------------------------------------
# These two are read by docker-compose itself (not baked into the
# site), so `docker compose up -d` applies them without a rebuild.
#
# CONTAINER_NAME  — name of the web container. Default: nettools
#CONTAINER_NAME=nettools

# DOCKER_NETWORK  — external Docker network to join, created by your
#                   reverse-proxy stack. Default: proxy_net
#DOCKER_NETWORK=proxy_net

# ---- Modules -------------------------------------------------
# DISABLED_MODULES — comma-separated list of tools to turn off.
#   All modules are ENABLED by default; list the slugs you want
#   hidden. A disabled tool is removed from the sidebar nav and the
#   home grid, and visiting its page directly redirects to home.
#   Valid slugs: subnet, tcpdump, fw-monitor, fw-zdebug,
#                compose-converter, mqtt, routemap
#   Example (disable the MQTT client and route-map builder):
#DISABLED_MODULES=mqtt,routemap

# ---- Branding ------------------------------------------------
# The sidebar logo is two side-by-side spans between brackets:
# [ LOGO_TEXT LOGO_ACCENT ]. LOGO_TEXT uses the primary text color;
# LOGO_ACCENT uses the accent/highlight color (COLOR_PRIMARY).
# Set them independently — either one left unset keeps its built-in
# default ("NET" and "TOOLS" respectively).
#
# LOGO_TEXT    — first (primary-color) part of the logo. Default: NET
#LOGO_TEXT=NET

# LOGO_ACCENT  — second (accent-color) part of the logo. Default: TOOLS
#LOGO_ACCENT=TOOLS

# LOGO_SUB     — muted subtitle line under the logo.
#                Default: // browser-local utilities
#LOGO_SUB=// browser-local utilities

# LOGO_LINK    — where clicking the sidebar logo goes. Can be a
#                relative path or a full URL (e.g. a parent portal).
#                Default: index.html (the NetTools home page)
#LOGO_LINK=https://example.com

# TAB_TITLE   — replaces the "NetTools" brand prefix in the
#               browser-tab title; each page keeps its own
#               "— Tool Name" suffix. Default: "NetTools".
#TAB_TITLE=ACME Tools

# ---- Colors (any valid CSS color: hex, rgb(), hsl(), name) ---
# COLOR_PRIMARY   — primary highlight / accent (links, focus,
#                   active nav, section labels). Default: #4dd9c0
#COLOR_PRIMARY=#4dd9c0

# COLOR_WARNING   — warning highlight (field warnings, badges).
#                   Default: #e6a817
#COLOR_WARNING=#e6a817

# COLOR_ERROR     — error highlight (validation errors).
#                   Default: #e05c5c
#COLOR_ERROR=#e05c5c

# COLOR_BG        — page background. Default: #0b0e14
#COLOR_BG=#0b0e14

# COLOR_INPUT_BG  — background of text inputs / selects.
#                   Default: #0b0e14
#COLOR_INPUT_BG=#0b0e14

# COLOR_BORDER    — general border color (panels, dividers).
#                   Default: #253045
#COLOR_BORDER=#253045

# ---- Typography ----------------------------------------------
# FONT_FAMILY — CSS font-family stack applied everywhere. Keep
#               the quoting exactly as a CSS value would use.
#               Default: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace
#FONT_FAMILY='JetBrains Mono', 'Fira Code', 'Consolas', monospace

# ---- Text sizes ----------------------------------------------
# TEXT_BASE_SIZE — root font size (px). Because the whole UI is
#                  sized in rem, this scales EVERYTHING up/down
#                  proportionally. Use px. Default: 14px
#TEXT_BASE_SIZE=14px

# The tokens below fine-tune individual text roles. Use rem so
# they continue to track TEXT_BASE_SIZE, or px for a fixed size.
# TEXT_TITLE_SIZE — tool page titles (h1). Default: 1.4rem
#TEXT_TITLE_SIZE=1.4rem

# TEXT_BODY_SIZE  — input / select text. Default: 0.9rem
#TEXT_BODY_SIZE=0.9rem

# TEXT_LABEL_SIZE — field labels above inputs. Default: 0.85rem
#TEXT_LABEL_SIZE=0.85rem

# TEXT_SMALL_SIZE — hint / helper text under inputs. Default: 0.7rem
#TEXT_SMALL_SIZE=0.7rem

# TEXT_NAV_SIZE   — sidebar navigation items. Default: 1rem
#TEXT_NAV_SIZE=1rem
